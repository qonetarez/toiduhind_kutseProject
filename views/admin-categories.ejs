<%- include('partials/header') %>

<section class="admin-page">
  <div class="admin-header">
    <h1>Admin: Kategooriad</h1>
  </div>

  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="success-alert"><%= success %></div>
  <% } %>

  <form method="post" action="/admin/categories" class="auth-form">
    <h2>Lisa uus kategooria</h2>
    <label>
      Kategooria nimi
      <input type="text" name="name" required />
    </label>
    <label>
      Kategooria ID (slug, valikuline)
      <input type="text" name="id" placeholder="nt joogid" />
    </label>
    <button type="submit">Lisa kategooria</button>
  </form>

  <% if (categories.length === 0) { %>
    <p>Kategooriaid veel pole.</p>
  <% } else { %>
    <div class="table-wrapper">
      <table class="price-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nimi</th>
            <th>Muuda</th>
            <th>Kustuta</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach(function(cat) { %>
            <tr>
              <td><%= cat.id %></td>
              <td><%= cat.name %></td>
              <td>
                <form method="post" action="/admin/categories/<%= cat.id %>" class="inline-form">
                  <input type="text" name="id" value="<%= cat.id %>" required />
                  <input type="text" name="name" value="<%= cat.name %>" required />
                  <button type="submit">Salvesta</button>
                </form>
              </td>
              <td>
                <form method="post" action="/admin/categories/<%= cat.id %>/delete" onsubmit="return confirm('Kustuta see kategooria?');">
                  <button type="submit" class="danger-btn">Kustuta</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
