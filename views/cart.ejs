<%- include('partials/header') %>

<section class="cart-page">
  <div class="cart-head">
    <h1>Ostukorv</h1>
    <% if (cart.length > 0) { %>
      <form method="post" action="/cart/clear">
        <button type="submit" class="danger-btn">Tuhjenda korv</button>
      </form>
    <% } %>
  </div>

  <% if (cart.length === 0) { %>
    <p>Korv on tühi.</p>
    <a href="/">Mine tagasi toodete juurde</a>
  <% } else { %>
    <div class="table-wrapper">
      <table class="price-table">
        <thead>
          <tr>
            <th>Toode</th>
            <th>Pood</th>
            <th>Hind</th>
            <th>Kogus</th>
            <th>Summa</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% cart.forEach(function(item) { %>
            <tr>
              <td>
                <% if (item.imageUrl) { %>
                  <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="cart-product-thumb" />
                <% } %>
                <a href="/product/<%= item.slug %>"><%= item.name %></a>
              </td>
              <td><%= item.storeName %></td>
              <td><%= item.price.toFixed(2) %> €</td>
              <td><%= item.qty %></td>
              <td><%= (item.price * item.qty).toFixed(2) %> €</td>
              <td>
                <form method="post" action="/cart/remove">
                  <input type="hidden" name="slug" value="<%= item.slug %>" />
                  <input type="hidden" name="storeId" value="<%= item.storeId %>" />
                  <button type="submit" class="danger-btn">Eemalda</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="cart-total">
      Kokku: <strong><%= total.toFixed(2) %> €</strong>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>

