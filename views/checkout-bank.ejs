<%- include('partials/header') %>

<section class="bank-page">
  <h1>
    <%= bankLabel %> makse
  </h1>
  <p class="bank-subtitle">
    Tegemist on panga eraldi maksevormiga. Sisesta andmed ja kinnita makse.
  </p>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <div class="bank-card">
    <p><strong>Maksja:</strong> <%= draft.firstName %> <%= draft.lastName %></p>
    <p><strong>Telefon:</strong> <%= draft.phone %></p>
    <p><strong>Aadress:</strong> <%= draft.address %></p>
    <p><strong>Summa:</strong> <%= total.toFixed(2) %> €</p>
    <% if (paymentConfig && paymentConfig.title) { %>
      <p><strong>Integratsioon:</strong> <%= paymentConfig.title %></p>
    <% } %>
    <% if (paymentConfig && paymentConfig.externalUrl) { %>
      <p>
        <a href="<%= paymentConfig.externalUrl %>" target="_blank" rel="noopener noreferrer">
          Ava panga ametlik test/leht
        </a>
      </p>
    <% } %>

    <form method="post" action="/checkout/confirm" class="auth-form">
      <input type="hidden" name="bank" value="<%= bank %>" />
      <% (paymentConfig && paymentConfig.fields ? paymentConfig.fields : []).forEach(function(field) { %>
        <label>
          <%= field.label %>
          <input
            type="text"
            name="<%= field.name %>"
            <%= field.required ? 'required' : '' %>
            placeholder="<%= field.placeholder || '' %>"
            value="<%= paymentForm && paymentForm[field.name] ? paymentForm[field.name] : '' %>"
          />
        </label>
      <% }) %>
      <button type="submit">Kinnita makse</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
