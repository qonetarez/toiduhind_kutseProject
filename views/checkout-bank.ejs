<%- include('partials/header') %>

<section class="bank-page">
  <h1>
    <%= bankLabel %> makse
  </h1>
  <p class="bank-subtitle">
    Tegemist on testvormiga. Sisesta andmed ja kinnita makse.
  </p>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <div class="bank-card">
    <p><strong>Maksja:</strong> <%= draft.firstName %> <%= draft.lastName %></p>
    <p><strong>Telefon:</strong> <%= draft.phone %></p>
    <p><strong>Aadress:</strong> <%= draft.address %></p>
    <p><strong>Summa:</strong> <%= total.toFixed(2) %> €</p>

    <form method="post" action="/checkout/confirm" class="auth-form">
      <input type="hidden" name="bank" value="<%= bank %>" />
      <label>
        Kasutaja number
        <input
          type="text"
          name="userNumber"
          required
          value="<%= paymentForm && paymentForm.userNumber ? paymentForm.userNumber : '' %>"
        />
      </label>
      <label>
        Isikukood
        <input
          type="text"
          name="isikukood"
          required
          value="<%= paymentForm && paymentForm.isikukood ? paymentForm.isikukood : '' %>"
        />
      </label>
      <button type="submit">Kinnita makse</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
