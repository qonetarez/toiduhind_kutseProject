<%- include('partials/header') %>

<section class="checkout-page">
  <h1>Vormista ost</h1>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>

  <div class="checkout-layout">
    <form method="post" action="/checkout" class="auth-form checkout-details-form">
      <label>
        Eesnimi
        <input type="text" name="firstName" required value="<%= form.firstName %>" />
      </label>
      <label>
        Perekonnanimi
        <input type="text" name="lastName" required value="<%= form.lastName %>" />
      </label>
      <label>
        Telefon
        <input type="text" name="phone" required value="<%= form.phone %>" />
      </label>
      <label>
        Aadress
        <input type="text" name="address" required value="<%= form.address %>" />
      </label>
      <div>
        <p><strong>Vali bank link</strong></p>
        <div class="bank-links-grid">
          <button type="submit" name="bank" value="swedbank" class="bank-link-btn">Swedbank</button>
          <button type="submit" name="bank" value="seb" class="bank-link-btn">SEB</button>
          <button type="submit" name="bank" value="lhv" class="bank-link-btn">LHV</button>
          <button type="submit" name="bank" value="luminor" class="bank-link-btn">Luminor</button>
          <button type="submit" name="bank" value="applepay" class="bank-link-btn">Apple Pay</button>
        </div>
      </div>
    </form>

    <aside class="checkout-summary">
      <h2>Sinu tellimus</h2>
      <% cart.forEach(function(item) { %>
        <div class="checkout-summary-row">
          <span><%= item.name %> x <%= item.qty %></span>
          <strong><%= (item.price * item.qty).toFixed(2) %> €</strong>
        </div>
      <% }) %>
      <div class="checkout-summary-total">
        Kokku: <strong><%= total.toFixed(2) %> €</strong>
      </div>
    </aside>
  </div>
</section>

<%- include('partials/footer') %>
