<%- include('partials/header') %>

<section class="admin-page">
  <h1>Kuller: Tasutud tellimused</h1>

  <% if (orders.length === 0) { %>
    <p>Tasutud tellimusi hetkel pole.</p>
  <% } else { %>
    <% orders.forEach(function(order) { %>
      <article class="order-card">
        <h2>Tellimus #<%= order.id %></h2>
        <p>
          Klient: <strong><%= order.customer_first_name %> <%= order.customer_last_name %></strong><br />
          Kasutaja number: <%= order.customer_user_number || '-' %><br />
          Isikukood: <%= order.customer_isikukood || '-' %><br />
          Telefon: <%= order.customer_phone %><br />
          Aadress: <%= order.customer_address %>
        </p>
        
        <p>
          Kasutaja: <%= order.user_username || order.user_email || '-' %><br />
          Pank: <%= order.bank %><br />
          Kokku: <strong><%= Number(order.total).toFixed(2) %> €</strong>
        </p>
        <div class="order-map">
          <iframe
            title="Kaart tellimusele <%= order.id %>"
            width="100%"
            height="220"
            style="border:0; border-radius:8px;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src="https://maps.google.com/maps?q=<%= encodeURIComponent(order.customer_address) %>&z=14&output=embed"
          ></iframe>
        </div>
        <div class="table-wrapper">
          <table class="price-table">
            <thead>
              <tr>
                <th>Toode</th>
                <th>Pood</th>
                <th>Hind</th>
                <th>Kogus</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(function(item) { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><%= item.store_name %></td>
                  <td><%= Number(item.price).toFixed(2) %> €</td>
                  <td><%= item.qty %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>

<%- include('partials/footer') %>
