<%- include('partials/header') %>

<section class="admin-page">
  <h1>Kuller: Koik tellimused</h1>

  <% if (orders.length === 0) { %>
    <p>Tellimusi hetkel pole.</p>
  <% } else { %>
    <% orders.forEach(function(order) { %>
      <article class="order-card">
        <h2>Tellimus #<%= order.id %></h2>
        <p>
          Staatus:
          <strong class="order-status-badge order-status-<%= order.status %>">
            <%= order.status === 'in_progress'
              ? 'Töös'
              : order.status === 'delivering'
                ? 'Teel kliendile'
                : order.status === 'delivered'
                  ? 'Katte toimetatud'
                  : 'Makstud' %>
          </strong>
        </p>
        <form method="post" action="/courier/orders/<%= order.id %>/status" class="status-actions">
          <button
            type="submit"
            name="status"
            value="in_progress"
            class="status-btn status-btn-progress"
            <%= (order.status === 'in_progress' || order.status === 'delivering' || order.status === 'delivered') ? 'disabled' : '' %>
          >
            Töös
          </button>
          <button
            type="submit"
            name="status"
            value="delivering"
            class="status-btn status-btn-delivering"
            <%= (order.status === 'delivering' || order.status === 'delivered') ? 'disabled' : '' %>
          >
            Teel kliendile
          </button>
          <button
            type="submit"
            name="status"
            value="delivered"
            class="status-btn status-btn-delivered"
            <%= order.status === 'delivered' ? 'disabled' : '' %>
          >
            Katte toimetatud
          </button>
        </form>
        <p>
          Klient: <strong><%= order.customer_first_name %> <%= order.customer_last_name %></strong><br />
          Telefon: <%= order.customer_phone %><br />
          Aadress: <%= order.customer_address %>
        </p>
        
        <p>
          Kasutaja: <%= order.user_username || order.user_email || '-' %><br />
          Pank: <%= order.bank %><br />
          Kokku: <strong><%= Number(order.total).toFixed(2) %> €</strong>
        </p>
        <div class="order-map">
          <iframe
            title="Kaart tellimusele <%= order.id %>"
            width="100%"
            height="220"
            style="border:0; border-radius:8px;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src="https://maps.google.com/maps?q=<%= encodeURIComponent(order.customer_address) %>&z=14&output=embed"
          ></iframe>
        </div>
        <div class="table-wrapper">
          <table class="price-table">
            <thead>
              <tr>
                <th>Toode</th>
                <th>Pood</th>
                <th>Hind</th>
                <th>Kogus</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(function(item) { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><%= item.store_name %></td>
                  <td><%= Number(item.price).toFixed(2) %> €</td>
                  <td><%= item.qty %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>

<%- include('partials/footer') %>
