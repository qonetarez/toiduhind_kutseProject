<!DOCTYPE html>
<html lang="et">
  <head>
    <meta charset="UTF-8" />
    <title>ToiduHind.ee</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <header class="header">
      <div class="container header-content">
        <a href="/" class="logo">ToiduHind.ee</a>
        <form class="header-search" method="get" action="/">
          <input
            type="text"
            name="q"
            placeholder="Millist toodet Te otsite?"
            value="<%= query || '' %>"
          />
          <% if (activeCategory && activeCategory !== 'all') { %>
            <input type="hidden" name="category" value="<%= activeCategory %>" />
          <% } %>
          <% if (sort) { %>
            <input type="hidden" name="sort" value="<%= sort %>" />
          <% } %>
          <button type="submit">Otsi</button>
        </form>
        <nav class="nav">
          <a href="/">Avaleht</a>
          <a href="/cart">Korv (<%= cartCount %>)</a>
          <% if (currentUser && currentUser.role === 'admin') { %>
            <a href="/admin/products">Tooted</a>
            <a href="/admin/categories">Kategooriad</a>
            <a href="/admin/users">Kasutajad</a>
          <% } %>
          <% if (currentUser && currentUser.role === 'courier') { %>
            <a href="/courier/orders">Kuller</a>
          <% } %>
          <% if (currentUser && currentUser.role === 'support') { %>
            <a href="/support/orders">Tugi</a>
          <% } %>
          <% if (currentUser) { %>
            <a href="/profile">Minu profiil</a>
            <form method="post" action="/logout" class="nav-logout-form">
              <button type="submit">Logi välja</button>
            </form>
          <% } else { %>
            <a href="/login">Logi sisse</a>
            <a href="/register">Loo konto</a>
          <% } %>
        </nav>
      </div>
    </header>
    <main class="container">

