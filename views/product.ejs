<%- include('partials/header') %>

<a href="/" class="back-link">← Tagasi avalehele</a>

<section class="product-detail">
  <h1><%= product.name %></h1>
  <p class="product-category">Kategooria: <%= product.category %></p>

  <h2>Hinnad poodides</h2>
  <div class="table-wrapper">
    <table class="price-table">
      <thead>
        <tr>
          <th>Pood</th>
          <th>Hind</th>
        </tr>
      </thead>
      <tbody>
        <% stores.forEach(store => { %>
          <tr>
            <td><%= store.name %></td>
            <td>
              <% const price = product.prices[store.id]; %>
              <%= price ? price.toFixed(2) + ' €' : 'Pole saadaval' %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>

