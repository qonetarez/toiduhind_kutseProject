<%- include('partials/header') %>

<section class="profile-page">
  <h1>Minu profiil</h1>
  <% if (error) { %>
    <div class="alert"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="success-alert"><%= success %></div>
  <% } %>
  <% if (currentUser.username) { %>
    <p>Kasutajanimi: <strong><%= currentUser.username %></strong></p>
  <% } %>
  <p>Oled sisse loginud kui: <strong><%= currentUser.email %></strong></p>
  <p>Roll: <strong><%= currentUser.role %></strong></p>

  <h2>Aktiivsed tellimused</h2>
  <% if (!activeOrders || activeOrders.length === 0) { %>
    <p>Sul ei ole hetkel aktiivseid tellimusi.</p>
  <% } else { %>
    <% activeOrders.forEach(function(order) { %>
      <article class="order-card">
        <h3>Tellimus #<%= order.user_order_number || order.id %></h3>
        <p>
          Kuupäev: <%= new Date(order.created_at).toLocaleString('et-EE') %><br />
          Staatus:
          <%= order.status === 'in_progress'
            ? 'Töös'
            : order.status === 'delivering'
              ? 'Teel kliendile'
              : order.status === 'delivered'
                ? 'Kohale toimetatud'
                : order.status === 'cancelled_by_user'
                  ? 'Kasutaja tühistas'
                : 'Makstud' %><br />
          Pank: <%= order.bank %><br />
          Kokku: <strong><%= Number(order.total).toFixed(2) %> €</strong>
        </p>
        <% if (order.status === 'paid' || order.status === 'in_progress') { %>
          <form method="post" action="/orders/<%= order.id %>/cancel" class="order-action-form">
            <label>
              Tühistamise põhjus
              <textarea name="reason" required placeholder="Kirjelda, miks soovid tellimuse tühistada"></textarea>
            </label>
            <button type="submit" class="danger-btn">Tühista tellimus</button>
          </form>
        <% } %>
        <div class="table-wrapper">
          <table class="price-table">
            <thead>
              <tr>
                <th>Toode</th>
                <th>Pood</th>
                <th>Hind</th>
                <th>Kogus</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(function(item) { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><%= item.store_name %></td>
                  <td><%= Number(item.price).toFixed(2) %> €</td>
                  <td><%= item.qty %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    <% }) %>
  <% } %>

  <h2>Eelmised tellimused</h2>
  <% if (!previousOrders || previousOrders.length === 0) { %>
    <p>Sul ei ole veel eelnevaid tellimusi.</p>
  <% } else { %>
    <% previousOrders.forEach(function(order) { %>
      <article class="order-card">
        <h3>Tellimus #<%= order.user_order_number || order.id %></h3>
        <p>
          Kuupäev: <%= new Date(order.created_at).toLocaleString('et-EE') %><br />
          Staatus:
          <%= order.status === 'cancelled_by_user'
            ? 'Kasutaja tühistas'
            : order.status === 'return_requested'
              ? 'Tagastussoov esitatud'
              : 'Kohale toimetatud' %><br />
          Pank: <%= order.bank %><br />
          Kokku: <strong><%= Number(order.total).toFixed(2) %> €</strong>
        </p>
        <% if (order.status === 'cancelled_by_user' && order.cancellation_reason) { %>
          <p><strong>Tühistamise põhjus:</strong> <%= order.cancellation_reason %></p>
        <% } %>
        <% if (order.status === 'return_requested') { %>
          <p><strong>Tagastuse põhjus:</strong> <%= order.return_reason || '-' %></p>
          <% if (order.return_photo_url) { %>
            <p>
              <strong>Tagastuse foto:</strong>
              <a href="<%= order.return_photo_url %>" target="_blank" rel="noopener noreferrer">Ava foto</a>
            </p>
            <p><img src="<%= order.return_photo_url %>" alt="Tagastuse foto" class="return-photo-preview" /></p>
          <% } %>
        <% } %>
        <% if (order.status === 'delivered') { %>
          <form method="post" action="/orders/<%= order.id %>/return" class="order-action-form" enctype="multipart/form-data">
            <label>
              Tagastuse põhjus
              <textarea name="returnReason" required placeholder="Kirjelda tagastuse põhjust"></textarea>
            </label>
            <label>
              Lisa foto (valikuline)
              <input type="file" name="returnPhoto" accept="image/*" />
            </label>
            <button type="submit" class="danger-btn">Tagasta tellimus</button>
          </form>
        <% } %>
        <form method="post" action="/orders/<%= order.id %>/repeat" style="margin-bottom: 10px;">
          <button type="submit" class="btn-primary">Korda tellimust</button>
        </form>
        <div class="table-wrapper">
          <table class="price-table">
            <thead>
              <tr>
                <th>Toode</th>
                <th>Pood</th>
                <th>Hind</th>
                <th>Kogus</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach(function(item) { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><%= item.store_name %></td>
                  <td><%= Number(item.price).toFixed(2) %> €</td>
                  <td><%= item.qty %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>

<%- include('partials/footer') %>

